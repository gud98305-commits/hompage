# ─── SEOULFIT 환경변수 (.env.example) ───
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env

# ─── OpenAI ───
OPENAI_API_KEY=

# ─── Stripe 결제 ───
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=jpy
JPY_RATE=0.11

# ─── 메일 (선택) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@seoulfit.local

# ─── DeepL 번역 ───
DEEPL_API_KEY=

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── JWT ───
JWT_SECRET=change-this-to-a-random-secret-string

# ─── 프론트엔드 URL ───
FRONTEND_URL=http://localhost:8001
REDIRECT_URI=http://localhost:8001/api/auth/callback

# ─── Turso (libsql) ───
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token-here

# ─── Google Drive (크롤러) ───
GDRIVE_SERVICE_ACCOUNT_PATH=./crawler/gdrive/service_account.json
GDRIVE_FOLDER_ID=your-drive-folder-id-here
